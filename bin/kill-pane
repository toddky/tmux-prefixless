#!/usr/bin/env bash

# Check if readonly
ro="$(tmux display-message -p '#{pane_input_off}')"
if ((ro)); then
	tmux display-message "Unable to kill-pane that is readonly"
	exit 0
fi

# Recursively search a process tree for a named child (depth-limited).
# Usage: has_child <pid> <name>...
# Echoes the matched name and returns 0, or returns 1 if not found.
has_child() {
	local pid=$1; shift
	local names=("$@")
	_has_child "$pid" 0 "${names[@]}"
}
_has_child() {
	local pid=$1 depth=$2; shift 2
	local names=("$@") children cpid exe name
	(( depth > 3 )) && return 1
	read -r children < /proc/"$pid"/task/"$pid"/children 2>/dev/null
	[[ -z "$children" ]] && return 1
	for cpid in $children; do
		exe=$(tr '\0' '\n' < /proc/"$cpid"/cmdline 2>/dev/null | head -1)
		exe=${exe##*/}
		for name in "${names[@]}"; do
			if [[ "$exe" == "$name" ]]; then
				echo "$name"; return 0
			fi
		done
		_has_child "$cpid" $((depth + 1)) "${names[@]}" && return 0
	done
	return 1
}
killed=0
pane_cmd="$(tmux display-message -p '#{pane_current_command}')"

case "$pane_cmd" in

	# Keep pane alive if running jobs
	nios|srun)
		tmux display-message "Unable to kill-pane running '$pane_cmd'"
		;;

	# Shells: check for important processes in the process tree before killing
	bash|fish|zsh)
		confirm_proc="$(has_child "$(tmux display-message -p '#{pane_pid}')" claude opencode python python3 uv)"
		if [[ -n "$confirm_proc" ]]; then
			tmux confirm-before -p "kill-pane running '$confirm_proc'? (y/n)" kill-pane && killed=1
		else
			tmux kill-pane
			killed=1
		fi
		;;

	# Confirm before killing pane
	nvim|vim|ssh)
		tmux confirm-before -p "kill-pane running '$pane_cmd'? (y/n)" kill-pane && killed=1
		;;

	# Kill pane immediately
	less|man)
		tmux kill-pane
		killed=1
		;;

	*)
		tmux confirm-before -p "kill-pane running '$pane_cmd'? (y/n)" kill-pane && killed=1
		;;
esac

if ((killed)); then
	 tmux resize-pane -y 999
fi

